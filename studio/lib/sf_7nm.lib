/* SiliconForge 7nm Standard Cell Library — sf_7nm */
/* Process: 7nm FinFET, 0.70V nominal, 25°C */
/* 82 cells: combinational + sequential + special */

library(sf_7nm) {
  technology(cmos);
  delay_model : table_lookup;
  nom_voltage : 0.70;
  nom_temperature : 25;
  nom_process : 1.0;
  time_unit : "1ns";
  voltage_unit : "1V";
  current_unit : "1mA";
  capacitive_load_unit(1, pf);
  pulling_resistance_unit : "1kohm";
  leakage_power_unit : "1nW";

  default_max_transition : 0.5;
  default_fanout_load : 1.0;
  default_inout_pin_cap : 0.004;
  default_input_pin_cap : 0.004;
  default_output_pin_cap : 0.0;

  operating_conditions(typical) {
    process : 1.0;
    voltage : 0.70;
    temperature : 25;
  }
  default_operating_conditions : typical;

  lu_table_template(delay_2x2) {
    variable_1 : input_net_transition;
    variable_2 : total_output_net_capacitance;
    index_1("0.01, 0.1");
    index_2("0.005, 0.05");
  }

  /* ================================================================ */
  /*  INVERTERS                                                       */
  /* ================================================================ */

  cell(INV_X1) {
    area : 0.798;
    cell_leakage_power : 2.1;
    pin(A) { direction : input; capacitance : 0.0032; }
    pin(Y) {
      direction : output;
      function : "!A";
      max_capacitance : 0.08;
      timing() {
        related_pin : "A";
        timing_sense : negative_unate;
        cell_rise(delay_2x2) { values("0.012, 0.035", "0.021, 0.048"); }
        cell_fall(delay_2x2) { values("0.010, 0.032", "0.019, 0.044"); }
        rise_transition(delay_2x2) { values("0.008, 0.028", "0.015, 0.038"); }
        fall_transition(delay_2x2) { values("0.007, 0.025", "0.013, 0.035"); }
      }
      internal_power() {
        related_pin : "A";
        rise_power(delay_2x2) { values("0.0008, 0.0010", "0.0009, 0.0012"); }
        fall_power(delay_2x2) { values("0.0006, 0.0008", "0.0007, 0.0010"); }
      }
    }
  }

  cell(INV_X2) {
    area : 1.064;
    cell_leakage_power : 4.2;
